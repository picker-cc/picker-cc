{
  "name": "@picker-cc/ui-devkit",
  "version": "0.1.0",
  "description": "A library for authoring Picker Admin UI extensions",
  "keywords": [
    "picker",
    "javascript",
    "extensions"
  ],
  "author": "baisheng <baisheng@gmail.com>",
  "homepage": "https://github.com/picker-cc/picker-cc#readme",
  "license": "ISC",
  "main": "lib/index.js",
  "directories": {
    "lib": "lib",
    "test": "__tests__"
  },
  "files": [
    "lib"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/picker-cc/picker-cc.git"
  },
  "scripts": {
    "build": "rimraf ./lib && rollup -c rollup.config.js --configProduction",
    "watch": "rimraf ./lib && rollup -c rollup.config.js -w",
    "lint": "tslint --fix --project ./"
  },
  "bugs": {
    "url": "https://github.com/picker-cc/picker-cc/issues"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^7.1.1",
    "rollup": "^1.32.0",
    "rollup-plugin-terser": "^5.2.0",
    "rollup-plugin-typescript2": "^0.26.0",
    "tslib": "^1.11.1",
    "typescript": "^3.8.3"
  },
  "dependencies": {
    "@picker-cc/common": "^0.1.0",
    "rxjs": "^6.5.4"
  }
}
